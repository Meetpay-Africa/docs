{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PayGrid",
  "colors": {
    "primary": "#e3ce49",
    "light": "#ecd95f",
    "dark": "#d4be3c"
  },
  "fonts": {
    "family": "Plus Jakarta Sans"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "quickstart",
              "guides/idempotency",
              "guides/errors"
            ]
          },
          {
            "group": "Payments",
            "pages": [
              {
                "group": "Create payment",
                "pages": [
                  "guides/payments/create-mobile",
                  "guides/payments/create-card",
                  "guides/payments/create-dynamic-qr"
                ]
              },
              "guides/payments/status"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "guides/webhooks",
              "guides/merchants/merchant-default-urls"
            ]
          },
          {
            "group": "Payouts & account",
            "pages": [
              "guides/payouts",
              "guides/account"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/ping"
            ]
          },
          {
            "group": "Account",
            "pages": [
              "api-reference/merchants/profile",
              "api-reference/merchants/update-profile",
              "api-reference/merchants/balance"
            ]
          },
          {
            "group": "Payments",
            "pages": [
              {
                "group": "Create payment",
                "pages": [
                  "api-reference/payments/create-mobile",
                  "api-reference/payments/create-card",
                  "api-reference/payments/create-dynamic-qr"
                ]
              },
              "api-reference/payments/status",
              "api-reference/payments/list",
              "api-reference/payments/refresh",
              "api-reference/payments/events"
            ]
          },
          {
            "group": "Payouts",
            "pages": [
              "api-reference/payouts/create",
              "api-reference/payouts/status",
              "api-reference/payouts/list"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Developer Dashboard",
          "href": "https://paygrid.briq.tz",
          "icon": "browser"
        }
      ]
    }
  },
  "redirects": [
    { "source": "/guides/ping", "destination": "/quickstart" },
    { "source": "/guides/payments/create", "destination": "/guides/payments/create-mobile" },
    { "source": "/api-reference/payments/create", "destination": "/api-reference/payments/create-mobile" },
    { "source": "/guides/payments/get", "destination": "/guides/payments/status" },
    { "source": "/guides/payments/list", "destination": "/guides/payments/status" },
    { "source": "/guides/payouts/create", "destination": "/guides/payouts" },
    { "source": "/guides/payouts/get", "destination": "/guides/payouts" },
    { "source": "/guides/payouts/list", "destination": "/guides/payouts" },
    { "source": "/guides/merchants/get-profile", "destination": "/guides/account" },
    { "source": "/guides/merchants/get-balance", "destination": "/guides/account" }
  ],
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:sms@briq.tz"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Go to Dashboard",
      "href": "https://paygrid.briq.tz"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://briq.tz"
    }
  }
}
