            ]
          },
          {
            "group": "Connection",
            "pages": [
              "guides/ping"
            ]
          },
          {
            "group": "Account",
            "pages": [
              "guides/merchants/get-profile",
              "guides/merchants/get-balance"
            ]
          },
          {
            "group": "Payments",
            "pages": [
              "guides/payments/create",
              "guides/payments/status",
              "guides/payments/get",
              "guides/payments/list"
            ]
          },
          {
            "group": "Payouts",
